{
  "name": "@zcloak/ai-agent",
  "version": "1.0.17",
  "description": "zCloak.ai Agent CLI — sign, verify, register",
  "bin": {
    "zcloak-ai": "./dist/cli.js"
  },
  "type": "module",
  "main": "./dist/utils.js",
  "types": "./dist/utils.d.ts",
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.js.map"
  ],
  "scripts": {
    "generate-types": "tsx scripts/generate-types.ts",
    "check-types": "tsx scripts/generate-types.ts --check",
    "prebuild": "npm run generate-types",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "npm run clean && npm run build",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "zcloak",
    "internet-computer",
    "agent",
    "sign",
    "canister"
  ],
  "dependencies": {
    "@dfinity/agent": "^3.4.3",
    "@dfinity/candid": "^3.4.3",
    "@dfinity/identity": "^3.4.3",
    "@dfinity/identity-secp256k1": "^3.4.3",
    "@dfinity/principal": "^3.4.3",
    "@dfinity/vetkeys": "^0.4.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@vitest/coverage-v8": "^4.0.18",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
